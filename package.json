{
  "name": "hermes",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.1",
  "scripts": {
    "dev:agent": "pnpm --filter @hermes/agent dev",
    "build": "pnpm -r build",
    "build:agent": "pnpm --filter @hermes/agent build",
    "start:agent": "pnpm --filter @hermes/agent start",
    "db:generate": "pnpm --filter @hermes/shared prisma:generate",
    "db:migrate": "pnpm --filter @hermes/shared prisma:migrate",
    "db:studio": "pnpm --filter @hermes/shared prisma:studio",
    "test:capture": "pnpm --filter @hermes/agent tsx scripts/test-capture.ts",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20"
  }
}
